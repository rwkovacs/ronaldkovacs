# Database (Supabase or any PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/invoicekit"

# NextAuth
AUTH_SECRET="your-random-secret-here"
AUTH_URL="http://localhost:3000"

# OAuth providers (optional — remove what you don't use)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe subscription price IDs (create these in your Stripe dashboard)
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
